# ============================================
# NurseSphere API — Environment Configuration
# ============================================
# Copy this file to .env and fill in values.

# ── Database ────────────────────────────────
# PostgreSQL (production / CI)
DATABASE_URL="postgresql://nursesphere:nursesphere@localhost:5432/nursesphere"

# SQLite (local development — uncomment below, comment above)
# DATABASE_URL="file:./dev.db"

# ── Redis ───────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Authentication ──────────────────────────
JWT_SECRET="change-me-to-a-secure-random-string"
JWT_EXPIRES_IN="7d"

# ── App ─────────────────────────────────────
PORT=4000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Encryption ──────────────────────────────
ENCRYPTION_KEY="change-me-to-32-char-encryption-key"

# ── AI Services ─────────────────────────────
XAI_API_KEY=your_xai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Email (SMTP) ────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@nursesphere.com

# ── Sentry (Error Tracking) ─────────────────
SENTRY_DSN=https://your-sentry-dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token
