# ============================================
# NurseSphere Web — Environment Configuration
# ============================================
# Copy this file to .env.local and fill in values.

# API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database (PostgreSQL)
DATABASE_URL=postgresql://nursesphere:nursesphere@localhost:5432/nursesphere

# JWT
JWT_SECRET=your-jwt-secret-here

# Stripe (publishable key for client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Stripe (secret key for server-side API routes)
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe webhook endpoint secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Encryption key for client-side crypto utilities
NEXT_PUBLIC_ENCRYPTION_KEY=change-me-to-32-char-key

# Sentry DSN for error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
